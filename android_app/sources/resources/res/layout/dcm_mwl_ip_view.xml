<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/white_shape"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="40dp">
            <TextView
                android:textSize="14sp"
                android:textColor="#6699ff"
                android:id="@+id/dcm_mwl_close"
                android:background="@drawable/btn_selector_bg"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="5dp"
                android:text="@string/Close"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
            <LinearLayout
                android:background="@drawable/blue_shape_box"
                android:layout_width="180dp"
                android:layout_height="30dp"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true">
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:id="@+id/select_dicom1"
                    android:background="@color/blue_light"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="DICOM1"
                    android:layout_weight="1"/>
                <View
                    android:background="@color/blue_light"
                    android:layout_width="0.5dp"
                    android:layout_height="match_parent"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/blue_light"
                    android:gravity="center"
                    android:id="@+id/select_dicom2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="DICOM2"
                    android:layout_weight="1"/>
                <View
                    android:background="@color/blue_light"
                    android:layout_width="0.5dp"
                    android:layout_height="match_parent"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/blue_light"
                    android:gravity="center"
                    android:id="@+id/select_work_list"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="Worklist"
                    android:layout_weight="1"/>
            </LinearLayout>
        </RelativeLayout>
        <View
            android:background="@android:color/black"
            android:layout_width="match_parent"
            android:layout_height="0.8dp"
            android:layout_marginTop="10dp"/>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/dcm1_ly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="This AE title"/>
                    <EditText
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:id="@+id/et_dcm1_ae_title"
                        android:background="@drawable/edittext_background"
                        android:paddingLeft="5dp"
                        android:paddingRight="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="25dp"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hospital/Clinic"/>
                    <EditText
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:id="@+id/et_dcm1_hospital"
                        android:background="@drawable/edittext_background"
                        android:paddingLeft="5dp"
                        android:paddingRight="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="25dp"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Service"/>
                    <EditText
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:id="@+id/et_dcm1_service"
                        android:background="@drawable/edittext_background"
                        android:paddingLeft="5dp"
                        android:paddingRight="5dp"
                        android:layout_width="200dp"
                        android:layout_height="25dp"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Physician"/>
                    <EditText
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:id="@+id/et_dcm1_physician"
                        android:background="@drawable/edittext_background"
                        android:paddingLeft="5dp"
                        android:paddingRight="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="25dp"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/dcm2_ly"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DICOM Store AE title"/>
                    <EditText
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:id="@+id/et_dcm2_ae_title"
                        android:background="@drawable/edittext_background"
                        android:paddingLeft="5dp"
                        android:paddingRight="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="25dp"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DICOM Store Server IP"/>
                    <EditText
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:id="@+id/et_dcm2_ip"
                        android:background="@drawable/edittext_background"
                        android:paddingLeft="5dp"
                        android:paddingRight="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="25dp"
                        android:layout_marginTop="10dp"
                        android:digits="0123456789."
                        android:inputType="numberDecimal"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Port"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <EditText
                            android:textSize="12sp"
                            android:textColor="@android:color/black"
                            android:id="@+id/et_dcm2_port"
                            android:background="@drawable/edittext_background"
                            android:paddingLeft="5dp"
                            android:paddingRight="5dp"
                            android:layout_width="200dp"
                            android:layout_height="25dp"
                            android:inputType="number"/>
                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"/>
                        <TextView
                            android:textSize="12sp"
                            android:textColor="#6699ff"
                            android:id="@+id/dcm2_ping"
                            android:background="@drawable/btn_selector_bg"
                            android:clickable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ping"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:text="@string/dcm_upload_delete"
                        android:layout_weight="1"/>
                    <Switch
                        android:id="@+id/dcm_delete_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/mwl_ly"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DICOM Worklist AE title"/>
                    <EditText
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:id="@+id/et_mwl_ae_title"
                        android:background="@drawable/edittext_background"
                        android:paddingLeft="5dp"
                        android:paddingRight="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="25dp"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DICOM Worklist Server IP"/>
                    <EditText
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:id="@+id/et_mwl_ip"
                        android:background="@drawable/edittext_background"
                        android:paddingLeft="5dp"
                        android:paddingRight="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="25dp"
                        android:layout_marginTop="10dp"
                        android:digits="0123456789."
                        android:inputType="numberDecimal"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="10dp">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@android:color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Port"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <EditText
                            android:textSize="12sp"
                            android:textColor="@android:color/black"
                            android:id="@+id/et_mwl_port"
                            android:background="@drawable/edittext_background"
                            android:paddingLeft="5dp"
                            android:paddingRight="5dp"
                            android:layout_width="200dp"
                            android:layout_height="25dp"
                            android:inputType="number"/>
                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"/>
                        <TextView
                            android:textSize="12sp"
                            android:textColor="#6699ff"
                            android:id="@+id/mwl_ping"
                            android:background="@drawable/btn_selector_bg"
                            android:clickable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ping"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</RelativeLayout>
