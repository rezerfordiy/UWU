<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/color_ex_information"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="3dp"
                android:layout_marginTop="10dp">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_timelabel"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MI"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_mi_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_tis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIS"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_tis_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIB"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_tib_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GN"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_gainlabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="F"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_f"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DR"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_dr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SRI"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_enh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Color:"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_gain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="F0"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_f0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STEER"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_steer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRF"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_prf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WF"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/color_ex_wf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </ScrollView>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <com.sonoptek.pvus_android.view.USScaleView
                android:id="@+id/color_ex_scale"
                android:layout_width="20dp"
                android:layout_height="match_parent"/>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="30dp">
                <com.sonoptek.pvus_android.view.USImageView
                    android:id="@+id/color_ex_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <ImageView
                    android:layout_gravity="right"
                    android:id="@+id/color_ex_grayBars"
                    android:layout_width="8dp"
                    android:layout_height="match_parent"/>
                <com.sonoptek.pvus_android.measure.USMarkView
                    android:id="@+id/color_ex_mark_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_gravity="bottom"
                    android:id="@+id/color_ex_live_label"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginBottom="45dp"
                    android:text="@string/freeze"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/colorTextWhite"
                    android:gravity="right"
                    android:layout_gravity="bottom|right"
                    android:id="@+id/color_ex_count_label"
                    android:paddingRight="2dp"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:layout_marginBottom="45dp"
                    android:text="0/0"/>
                <ImageButton
                    android:id="@+id/color_ex_clean"
                    android:background="@drawable/del"
                    android:visibility="invisible"
                    android:layout_width="20dp"
                    android:layout_height="20dp"/>
                <EditText
                    android:textColor="@android:color/white"
                    android:id="@+id/color_ex_annote_editext"
                    android:background="@drawable/bg_edittext"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:textSize="10sp"
        android:textColor="@color/colorTextWhite"
        android:id="@+id/colorbar_top_label"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:layout_marginRight="10dp"
        android:text=""
        android:layout_alignParentRight="true"/>
    <ImageView
        android:id="@+id/color_ex_colorbar"
        android:layout_width="10dp"
        android:layout_height="100dp"
        android:layout_marginTop="100dp"
        android:layout_marginRight="15dp"
        android:layout_alignParentRight="true"/>
    <TextView
        android:textSize="10sp"
        android:textColor="@color/colorTextWhite"
        android:id="@+id/colorbar_bottom_label"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="210dp"
        android:layout_marginRight="15dp"
        android:text=""
        android:layout_alignParentRight="true"/>
    <RelativeLayout
        android:id="@+id/color_ex_fivebuttons_layout"
        android:visibility="invisible"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="30dp"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/color_ex_btn_out_left"
                android:background="@null"
                android:visibility="invisible"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_minus"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/color_ex_btn_up"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_up"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/color_ex_btn_out_right"
                android:background="@null"
                android:visibility="invisible"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_add"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_centerVertical="true">
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/color_ex_btn_left"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_left"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <ImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/color_ex_btn_sure"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_save"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/color_ex_btn_right"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_right"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true">
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/color_ex_btn_down"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_down"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
