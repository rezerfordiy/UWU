<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/pw_information"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="3dp"
            android:layout_marginTop="0dp">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_timelabel"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MI"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_mi_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_tis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIS"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_tis_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIS"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_tib_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GN"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_gainlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="F"
                android:alpha="0.5"/>
            <TextView
                android:textSize="12sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_enhance_f"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DR"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_enhance_dr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SRI"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_enhance_enh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_pwlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PW GN"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_pwgainlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STEER"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_steer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SV"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_volume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Angle"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/pw_angle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <com.sonoptek.pvus_android.view.USScaleView
                    android:id="@+id/pw_scale"
                    android:layout_width="20dp"
                    android:layout_height="match_parent"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.sonoptek.pvus_android.view.USImageView
                        android:id="@+id/pw_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <ImageView
                        android:layout_gravity="right"
                        android:id="@+id/pw_grayBars"
                        android:layout_width="8dp"
                        android:layout_height="match_parent"/>
                    <com.sonoptek.pvus_android.measure.USMarkView
                        android:id="@+id/pw_measure"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <ImageButton
                        android:id="@+id/pw_clean"
                        android:background="@drawable/del"
                        android:visibility="invisible"
                        android:layout_width="20dp"
                        android:layout_height="20dp"/>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="@color/colorTextWhite"
                        android:layout_gravity="bottom"
                        android:id="@+id/pw_livelabel"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:text="@string/freeze"/>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="@color/colorTextWhite"
                        android:gravity="right"
                        android:layout_gravity="bottom|right"
                        android:id="@+id/pw_countlabel"
                        android:paddingRight="2dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/pw_fivebuttons_layout"
        android:visibility="invisible"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="30dp"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/pw_btn_out_left"
                android:background="@null"
                android:visibility="invisible"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_minus"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/pw_btn_up"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_up"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/pw_btn_out_right"
                android:background="@null"
                android:visibility="invisible"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_add"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_centerVertical="true">
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/pw_btn_left"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_left"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <ImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/pw_btn_sure"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_save"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/pw_btn_right"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_right"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true">
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/pw_btn_down"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_down"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
