<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/bm_information"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="3dp"
            android:layout_marginTop="10dp">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/bm_timelabel"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MI"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/bm_mi_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/bm_tis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIS"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/bm_tis_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIB"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/bm_tib_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GN"
                android:alpha="0.5"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorTextWhite"
                android:id="@+id/bm_gainlabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/bm_enhance_lay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="F"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/bm_enhance_f"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="DR"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/bm_enhance_dr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="SRI"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/bm_enhance_enh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <com.sonoptek.pvus_android.view.USScaleView
                android:id="@+id/bm_scale"
                android:layout_width="20dp"
                android:layout_height="match_parent"/>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <com.sonoptek.pvus_android.view.USImageView
                    android:id="@+id/bm_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <ImageView
                    android:layout_gravity="right"
                    android:id="@+id/bm_grayBars"
                    android:layout_width="8dp"
                    android:layout_height="match_parent"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_gravity="bottom"
                    android:id="@+id/bm_livelabel"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:text="@string/freeze"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/colorTextWhite"
                    android:gravity="right"
                    android:layout_gravity="bottom|right"
                    android:id="@+id/bm_countlabel"
                    android:paddingRight="2dp"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"/>
                <com.sonoptek.pvus_android.measure.USMarkView
                    android:id="@+id/bm_measure"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
                <ImageButton
                    android:id="@+id/bm_clean"
                    android:background="@drawable/del"
                    android:visibility="invisible"
                    android:layout_width="20dp"
                    android:layout_height="20dp"/>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
