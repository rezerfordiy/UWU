<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/cd_information"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="3dp"
                android:layout_marginTop="0dp">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_timelabel"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MI"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_mi_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_tis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIS"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_tis_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIB"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_tib_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GN"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_gainlabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="F"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_enhance_f"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DR"
                    android:alpha="0.5"/>
                <TextView
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_enhance_dr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SRI"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_enhance_enh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_pwlabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PW GN"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_pwgainlabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="F0"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_f0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STEER"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_steer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SV"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Angle"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_angle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRF"
                    android:alpha="0.5"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/colorTextWhite"
                    android:id="@+id/cd_prf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </ScrollView>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <com.sonoptek.pvus_android.view.USScaleView
                    android:id="@+id/cd_scale"
                    android:layout_width="20dp"
                    android:layout_height="match_parent"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <com.sonoptek.pvus_android.view.USImageView
                        android:id="@+id/cd_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <com.sonoptek.pvus_android.measure.USMarkView
                        android:id="@+id/cd_measure"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <ImageButton
                        android:id="@+id/cd_clean"
                        android:background="@drawable/del"
                        android:visibility="invisible"
                        android:layout_width="20dp"
                        android:layout_height="20dp"/>
                    <ImageView
                        android:layout_gravity="right"
                        android:id="@+id/cd_grayBars"
                        android:layout_width="8dp"
                        android:layout_height="match_parent"/>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="@color/colorTextWhite"
                        android:layout_gravity="bottom"
                        android:id="@+id/cd_livelabel"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:text="@string/freeze"/>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="@color/colorTextWhite"
                        android:gravity="right"
                        android:layout_gravity="end|bottom"
                        android:id="@+id/cd_countlabel"
                        android:paddingRight="2dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/cd_fivebuttons_layout"
        android:visibility="invisible"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="30dp"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp">
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/cd_btn_out_left"
                android:background="@null"
                android:visibility="invisible"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_minus"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/cd_btn_up"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_up"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/cd_btn_out_right"
                android:background="@null"
                android:visibility="invisible"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_add"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_centerVertical="true">
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/cd_btn_left"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_left"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <ImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/cd_btn_sure"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_save"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/cd_btn_right"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_right"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true">
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <com.sonoptek.pvus_android.USImageButton
                android:layout_gravity="center_vertical"
                android:id="@+id/cd_btn_down"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:src="@drawable/btn_down"
                android:scaleType="fitXY"
                android:layout_weight="1"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
